# Copy to `.env` for local development and tweak as needed.
# docker-compose.yml reads these values; all are optional and default to
# the values below (safe for local-only, not for production).

# Which Fiely image to run. Defaults to the latest published build from GHCR.
# Pin a specific SHA or branch tag for reproducibility, e.g.:
#   FIELY_IMAGE=ghcr.io/benjaminledel/fiely:sha-abc1234
FIELY_IMAGE=ghcr.io/benjaminledel/fiely:latest

# Port exposed on the host
FIELY_PORT=8080

# Database
FIELY_DB_NAME=fiely
FIELY_DB_USER=fiely
FIELY_DB_PASSWORD=fiely
